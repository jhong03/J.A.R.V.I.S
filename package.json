{
  "name": "jarvis-dashboard",
  "version": "1.0.0",
  "description": "A JARVIS-inspired personal desktop dashboard with an embedded Claude Code console.",
  "author": "jhong03",
  "homepage": "https://github.com/jhong03/J.A.R.V.I.S",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "setup-voice": "powershell -ExecutionPolicy Bypass -File scripts/setup-voice.ps1"
  },
  "build": {
    "appId": "com.personal.jarvisdashboard",
    "productName": "JARVIS Dashboard",
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "files": [
      "main.js",
      "preload.js",
      "config.example.json",
      "src/**/*"
    ],
    "extraResources": [
      { "from": "vendor/piper", "to": "piper", "filter": ["**/*"] },
      { "from": "vendor/ffmpeg", "to": "ffmpeg", "filter": ["**/*"] }
    ]
  },
  "dependencies": {
    "systeminformation": "^5.23.5",
    "imapflow": "^1.0.164"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
