# dependencies — restored with `npm install`
node_modules/

# build output — rebuilt with `npm run dist` (contains config.json with secrets)
dist/

# personal config: holds IMAP app password and Spotify client id.
# copy config.example.json to config.json and fill in your own values.
config.json

# bundled voice engines: Piper TTS + model and the ffmpeg post-processor
# (large binaries). Restored with `npm run setup-voice` (see README voice setup).
vendor/
